<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LaundryPro - Solusi Cuci Modern</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap');
        
        body {
            font-family: 'Plus+Jakarta+Sans', sans-serif;
            background-color: #f8fafc;
            color: #1e293b;
            padding-bottom: 100px;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(226, 232, 240, 0.8);
        }

        .gradient-blue {
            background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
        }

        .status-badge {
            padding: 4px 10px;
            border-radius: 999px;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
        }

        @keyframes slideUp {
            from { transform: translateY(20px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        .animate-slide-up { animation: slideUp 0.4s ease-out forwards; }

        .modal-active {
            display: flex !important;
            animation: fadeIn 0.2s ease-out;
        }
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
    </style>
</head>
<body>

    <!-- Header / Navbar -->
    <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-100 px-5 py-4 flex justify-between items-center">
        <div class="flex items-center gap-2">
            <div class="w-8 h-8 gradient-blue rounded-lg flex items-center justify-center text-white">
                <i class="fas fa-soap"></i>
            </div>
            <span class="font-bold text-xl tracking-tight">Laundry<span class="text-blue-600">Pro</span></span>
        </div>
        <div class="flex gap-4 items-center">
            <button onclick="toggleView('history')" class="text-slate-500 hover:text-blue-600 transition-colors">
                <i class="fas fa-history text-xl"></i>
            </button>
            <button onclick="openAdminLogin()" class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500">
                <i class="fas fa-user-shield"></i>
            </button>
        </div>
    </nav>

    <!-- Main Content -->
    <main id="app-container" class="max-w-md mx-auto p-5">
        
        <!-- View: Home / Order -->
        <section id="view-home" class="animate-slide-up">
            <div class="mb-6">
                <h1 class="text-2xl font-bold mb-2">Halo, Selamat Datang! 👋</h1>
                <p class="text-slate-500 text-sm italic">Pakaian bersih, hati senang. Pesan jemputan sekarang.</p>
            </div>

            <div class="grid grid-cols-2 gap-4 mb-8">
                <div onclick="openModal('priceModal')" class="p-4 bg-blue-50 rounded-2xl flex flex-col items-center text-center gap-2 border border-blue-100 cursor-pointer">
                    <i class="fas fa-list-alt text-blue-500 text-2xl"></i>
                    <span class="text-xs font-bold text-blue-700">Cek Harga Satuan</span>
                </div>
                <div onclick="window.location.href='https://wa.me/628123456789'" class="p-4 bg-green-50 rounded-2xl flex flex-col items-center text-center gap-2 border border-green-100 cursor-pointer">
                    <i class="fas fa-headset text-green-500 text-2xl"></i>
                    <span class="text-xs font-bold text-green-700">Hubungi Admin</span>
                </div>
            </div>

            <!-- Form -->
            <div class="glass-card p-6 rounded-3xl shadow-md mb-8">
                <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
                    <i class="fas fa-truck-loading text-blue-600"></i> Form Penjemputan
                </h2>
                
                <form id="orderForm" class="space-y-4">
                    <div>
                        <label class="text-xs font-semibold text-slate-500 uppercase ml-1">Nama Lengkap</label>
                        <input type="text" id="custName" required placeholder="Nama Anda" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-500 outline-none">
                    </div>
                    <div>
                        <label class="text-xs font-semibold text-slate-500 uppercase ml-1">No. WhatsApp</label>
                        <input type="tel" id="custWhatsapp" required placeholder="08xxx" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-500 outline-none">
                    </div>
                    <div>
                        <label class="text-xs font-semibold text-slate-500 uppercase ml-1">Jenis Layanan</label>
                        <select id="serviceType" onchange="calculatePrice()" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 outline-none">
                            <option value="Cuci Lipat">Cuci Lipat (Rp 6.000/kg)</option>
                            <option value="Cuci Setrika">Cuci Setrika (Rp 8.000/kg)</option>
                            <option value="Express">Express 1 Hari (Rp 12.000/kg)</option>
                        </select>
                    </div>
                    <div class="flex gap-4">
                        <div class="flex-1">
                            <label class="text-xs font-semibold text-slate-500 uppercase ml-1">Berat (kg)</label>
                            <input type="number" id="weight" value="1" min="1" oninput="calculatePrice()" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 outline-none">
                        </div>
                        <div class="flex-1">
                            <label class="text-xs font-semibold text-slate-500 uppercase ml-1">Total</label>
                            <div id="totalDisplay" class="font-bold text-blue-600 py-3 text-lg">Rp 6.000</div>
                        </div>
                    </div>
                    <div>
                        <label class="text-xs font-semibold text-slate-500 uppercase ml-1">Alamat Lengkap</label>
                        <textarea id="address" rows="2" placeholder="Jl..." class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 outline-none"></textarea>
                    </div>
                    <button type="submit" id="submitBtn" class="w-full gradient-blue text-white font-bold py-4 rounded-xl shadow-lg active:scale-95 transition-all">
                        Kirim Order Penjemputan
                    </button>
                </form>
            </div>
        </section>

        <!-- View: History (User) -->
        <section id="view-history" class="hidden animate-slide-up">
            <div class="flex items-center justify-between mb-6">
                <div class="flex items-center gap-4">
                    <button onclick="toggleView('home')" class="w-10 h-10 rounded-full bg-white shadow-sm flex items-center justify-center">
                        <i class="fas fa-arrow-left"></i>
                    </button>
                    <h1 class="text-xl font-bold">Lacak Pesanan</h1>
                </div>
            </div>
            <div id="orderList" class="space-y-4 pb-20"></div>
        </section>

        <!-- View: Admin Panel -->
        <section id="view-admin" class="hidden animate-slide-up">
            <div class="flex items-center justify-between mb-6">
                <div class="flex items-center gap-4">
                    <button onclick="toggleView('home')" class="w-10 h-10 rounded-full bg-white shadow-sm flex items-center justify-center">
                        <i class="fas fa-times text-red-500"></i>
                    </button>
                    <h1 class="text-xl font-bold text-red-600">Admin Dashboard</h1>
                </div>
                <button onclick="refreshAdminData()" class="text-blue-500"><i class="fas fa-sync-alt"></i></button>
            </div>
            
            <div id="adminOrderList" class="space-y-4 pb-20">
                <!-- Admin orders appear here -->
            </div>
        </section>

    </main>

    <!-- Modals -->
    <div id="priceModal" class="fixed inset-0 bg-slate-900/60 z-[100] hidden items-end justify-center p-4">
        <div class="bg-white w-full max-w-md rounded-t-[32px] p-6 animate-slide-up">
            <h3 class="font-bold text-lg mb-4">Daftar Harga Satuan</h3>
            <div class="space-y-3 mb-6">
                <div class="flex justify-between p-3 bg-slate-50 rounded-xl"><span>Bed Cover</span><span class="font-bold">Rp 35rb</span></div>
                <div class="flex justify-between p-3 bg-slate-50 rounded-xl"><span>Jas 1 Set</span><span class="font-bold">Rp 25rb</span></div>
                <div class="flex justify-between p-3 bg-slate-50 rounded-xl"><span>Sepatu</span><span class="font-bold">Rp 30rb</span></div>
            </div>
            <button onclick="closeModal('priceModal')" class="w-full bg-slate-100 py-3 rounded-xl font-bold">Tutup</button>
        </div>
    </div>

    <!-- Modal: Admin Login -->
    <div id="adminLoginModal" class="fixed inset-0 bg-slate-900/60 z-[100] hidden items-center justify-center p-6">
        <div class="bg-white w-full max-w-xs rounded-3xl p-6 shadow-2xl">
            <div class="text-center mb-4">
                <i class="fas fa-lock text-3xl text-blue-600 mb-2"></i>
                <h3 class="font-bold">Akses Admin</h3>
            </div>
            <input type="password" id="adminPin" placeholder="Masukkan PIN" class="w-full text-center text-2xl tracking-[1em] border-b-2 border-blue-500 py-2 outline-none mb-4">
            <div class="flex gap-2">
                <button onclick="closeModal('adminLoginModal')" class="flex-1 py-2 text-slate-500 font-bold">Batal</button>
                <button onclick="checkAdminPin()" class="flex-1 py-2 bg-blue-600 text-white rounded-xl font-bold">Masuk</button>
            </div>
        </div>
    </div>

    <!-- Bottom Nav -->
    <div class="fixed bottom-6 left-1/2 -translate-x-1/2 w-[90%] max-w-md flex gap-3 z-40">
        <a href="https://wa.me/628123456789" class="w-14 h-14 bg-green-500 text-white rounded-2xl flex items-center justify-center shadow-lg"><i class="fab fa-whatsapp text-2xl"></i></a>
        <button onclick="toggleView('home')" class="flex-1 gradient-blue text-white rounded-2xl font-bold shadow-lg flex items-center justify-center gap-2">
            <i class="fas fa-plus"></i> Pesan Baru
        </button>
    </div>

    <div id="toast" class="fixed top-10 left-1/2 -translate-x-1/2 bg-slate-800 text-white px-6 py-3 rounded-full text-xs font-bold opacity-0 transition-opacity z-[200]"></div>

    <script>
        // Ganti dengan URL Web App Anda
        const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbwU3Wn54BFCVD6NxoyfrpkShTFzejq85ipBDwBhVgXobhwjBK5lOYsMQu6kL_yMZbtjLQ/exec"; 
        const ADMIN_PIN = "sur"; // PIN Standar

        let allOrders = JSON.parse(localStorage.getItem('laundry_orders')) || [];

        function showToast(msg) {
            const t = document.getElementById('toast');
            t.innerText = msg;
            t.classList.add('opacity-100');
            setTimeout(() => t.classList.remove('opacity-100'), 3000);
        }

        function toggleView(view) {
            document.getElementById('view-home').classList.add('hidden');
            document.getElementById('view-history').classList.add('hidden');
            document.getElementById('view-admin').classList.add('hidden');
            
            if (view === 'home') document.getElementById('view-home').classList.remove('hidden');
            if (view === 'history') {
                document.getElementById('view-history').classList.remove('hidden');
                renderUserOrders();
            }
            if (view === 'admin') {
                document.getElementById('view-admin').classList.remove('hidden');
                renderAdminOrders();
            }
        }

        function openModal(id) { document.getElementById(id).classList.add('modal-active'); }
        function closeModal(id) { document.getElementById(id).classList.remove('modal-active'); }

        function openAdminLogin() { 
            document.getElementById('adminPin').value = '';
            openModal('adminLoginModal'); 
        }

        function checkAdminPin() {
            const pin = document.getElementById('adminPin').value;
            if (pin === ADMIN_PIN) {
                closeModal('adminLoginModal');
                toggleView('admin');
            } else {
                showToast("PIN Salah!");
            }
        }

        function calculatePrice() {
            const s = document.getElementById('serviceType').value;
            const w = document.getElementById('weight').value || 0;
            let p = 6000;
            if (s === 'Cuci Setrika') p = 8000;
            if (s === 'Express') p = 12000;
            const total = p * w;
            document.getElementById('totalDisplay').innerText = `Rp ${total.toLocaleString('id-ID')}`;
            return total;
        }

        // --- CRUD LOGIC ---

        function renderUserOrders() {
            const list = document.getElementById('orderList');
            list.innerHTML = allOrders.length === 0 ? '<p class="text-center py-10 opacity-50">Belum ada pesanan</p>' : 
            allOrders.map(o => `
                <div class="glass-card p-4 rounded-2xl shadow-sm border-l-4 border-blue-500">
                    <div class="flex justify-between items-start mb-2">
                        <span class="text-[10px] font-bold text-slate-400">#${o.id}</span>
                        <span class="status-badge ${getStatusClass(o.status)}">${o.status}</span>
                    </div>
                    <div class="font-bold text-sm">${o.service} (${o.weight}kg)</div>
                    <div class="text-[10px] text-slate-500 mt-1">${new Date(o.timestamp).toLocaleString('id-ID')}</div>
                </div>
            `).join('');
        }

        function renderAdminOrders() {
            const list = document.getElementById('adminOrderList');
            list.innerHTML = allOrders.length === 0 ? '<p class="text-center py-10 opacity-50">Database Kosong</p>' : 
            allOrders.map((o, index) => `
                <div class="glass-card p-4 rounded-2xl shadow-sm border-t-4 border-slate-800">
                    <div class="flex justify-between items-center mb-3">
                        <span class="font-bold text-blue-600">ID: #${o.id}</span>
                        <button onclick="deleteOrder(${index})" class="text-red-400 text-xs"><i class="fas fa-trash"></i> Hapus</button>
                    </div>
                    <div class="grid grid-cols-2 gap-2 text-xs mb-4">
                        <div><p class="text-slate-400">Nama:</p> <p class="font-bold">${o.name}</p></div>
                        <div><p class="text-slate-400">WA:</p> <p class="font-bold">${o.whatsapp}</p></div>
                        <div class="col-span-2"><p class="text-slate-400">Alamat:</p> <p class="font-bold">${o.address}</p></div>
                        <div><p class="text-slate-400">Total:</p> <p class="font-bold text-green-600">Rp ${parseInt(o.total).toLocaleString('id-ID')}</p></div>
                    </div>
                    <div class="flex gap-2">
                        <select onchange="updateStatus(${index}, this.value)" class="flex-1 bg-slate-100 p-2 rounded-lg text-[10px] font-bold outline-none">
                            <option ${o.status === 'Menunggu Kurir' ? 'selected' : ''}>Menunggu Kurir</option>
                            <option ${o.status === 'Proses Cuci' ? 'selected' : ''}>Proses Cuci</option>
                            <option ${o.status === 'Selesai' ? 'selected' : ''}>Selesai</option>
                        </select>
                        <a href="https://wa.me/${o.whatsapp}" class="bg-green-100 text-green-600 px-3 flex items-center rounded-lg"><i class="fab fa-whatsapp"></i></a>
                    </div>
                </div>
            `).join('');
        }

        function getStatusClass(status) {
            if (status === 'Selesai') return 'bg-green-100 text-green-700';
            if (status === 'Proses Cuci') return 'bg-orange-100 text-orange-700';
            return 'bg-blue-100 text-blue-700';
        }

        // UPDATE
        function updateStatus(index, newStatus) {
            allOrders[index].status = newStatus;
            saveOrders();
            showToast("Status Diperbarui");
            renderAdminOrders();
        }

        // DELETE
        function deleteOrder(index) {
            if(confirm("Hapus data ini?")) {
                allOrders.splice(index, 1);
                saveOrders();
                renderAdminOrders();
                showToast("Data Dihapus");
            }
        }

        function saveOrders() {
            localStorage.setItem('laundry_orders', JSON.stringify(allOrders));
            // Catatan: Jika ingin integrasi Sheet penuh, di sini juga panggil API Update/Delete Sheet
        }

        // CREATE
        document.getElementById('orderForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML = 'Mengirim...';

            const newOrder = {
                id: Math.floor(1000 + Math.random() * 9000),
                name: document.getElementById('custName').value,
                whatsapp: document.getElementById('custWhatsapp').value,
                service: document.getElementById('serviceType').value,
                weight: document.getElementById('weight').value,
                total: calculatePrice(),
                address: document.getElementById('address').value,
                status: 'Menunggu Kurir',
                timestamp: new Date().toISOString()
            };

            allOrders.unshift(newOrder);
            saveOrders();

            if (SCRIPT_URL) {
                try {
                    await fetch(SCRIPT_URL, {
                        method: 'POST',
                        mode: 'no-cors',
                        body: JSON.stringify(newOrder)
                    });
                } catch (err) { console.error(err); }
            }

            setTimeout(() => {
                showToast("Order Sukses!");
                document.getElementById('orderForm').reset();
                calculatePrice();
                btn.disabled = false;
                btn.innerText = "Kirim Order Penjemputan";
                toggleView('history');
            }, 1000);
        });

        window.onload = calculatePrice;
    </script>
</body>
</html>
